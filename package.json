{
  "name": "ocr-tutor-monorepo",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev:web": "pnpm --filter ocr-tutor-demo dev",
    "dev:api": "pnpm --filter ocr-tutor-service dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "db:up": "pnpm --filter ocr-tutor-service db:up",
    "db:down": "pnpm --filter ocr-tutor-service db:down"
  }
}
