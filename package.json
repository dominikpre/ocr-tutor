{
  "name": "ocr-tutor-monorepo",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "scripts": {
    "dev:web": "pnpm --filter @ocr-tutor/web dev",
    "dev:api": "pnpm db:up && pnpm --filter @ocr-tutor/api dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "db:up": "pnpm --filter @ocr-tutor/api db:up",
    "db:down": "pnpm --filter @ocr-tutor/api db:down"
  }
}
