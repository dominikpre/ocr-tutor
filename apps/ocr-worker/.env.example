# Postgres connection used by Prisma for claim/update operations.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ocr_tutor?schema=public"
# Polling cadence for finding new submissions to process.
OCR_POLL_INTERVAL_MS=3000
# Number of submissions to claim per polling tick.
OCR_CLAIM_BATCH_SIZE=2
# Max OCR attempts before a submission is marked as failed.
OCR_MAX_ATTEMPTS=3
# Delay between automatic retries for failed OCR attempts.
OCR_RETRY_DELAY_MS=120000
# How OCR worker resolves submission image bytes today.
SUBMISSION_STORAGE_DRIVER="local"
# Shared uploads location (defaults to ../api/uploads from this package).
UPLOADS_DIR="../api/uploads"
# Ollama endpoint. Can be a full URL or plain host/IP[:port].
OLLAMA_BASE_URL="http://127.0.0.1:11434"
# Vision model available in the target Ollama runtime.
OLLAMA_MODEL="llava:7b"
# Optional bearer token for reverse-proxied endpoints.
OLLAMA_API_KEY=""
# Timeout per OCR request.
OLLAMA_REQUEST_TIMEOUT_MS=120000
