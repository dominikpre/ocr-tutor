{
  "name": "@ocr-tutor/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "ocrTutorCompatibility": {
    "contractVersion": "1",
    "web": "^0.1.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prisma:generate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/ocr_tutor?schema=public}\" prisma generate",
    "prisma:migrate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/ocr_tutor?schema=public}\" prisma migrate dev"
  },
  "dependencies": {
    "@ocr-tutor/contracts": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/static": "^8.3.0",
    "@prisma/client": "^6.7.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "image-size": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "prisma": "^6.7.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
