# Postgres connection used by Prisma and the Fastify service.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ocr_tutor?schema=public"
# HTTP port for the backend service itself.
PORT=4000
# Base URL written into image URLs returned to the frontend.
PUBLIC_BASE_URL="http://localhost:4000"
# Browser origin allowed to call the backend directly during local development.
FRONTEND_ORIGIN="http://localhost:3000"
# Where uploaded files are stored on disk, relative to the service repo root.
UPLOADS_DIR="uploads"
# 10 MB per file upload limit.
MAX_FILE_SIZE_BYTES=10485760
# 20 file uploads per request limit.
MAX_FILE_COUNT=50
